# ScrantonOS Environment Configuration
# Copy this file to .env and fill in your values

# Environment mode: "DEV" or "PROD"
ENV=DEV

# Gemini API Key (required for agent LLM calls)
# Get one at: https://aistudio.google.com/app/api-keys
GEMINI_API_KEY=

# GCP Configuration (only required in PROD mode)
GCP_PROJECT_ID=
GCP_REGION=us-central1

# Security
# HMAC secret for signing HITL approval tokens
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
IAM_APPROVAL_SECRET=dev-secret-not-for-production

# Limits
MAX_TOKEN_BUDGET=50000
